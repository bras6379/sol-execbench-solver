# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
build/
dist/

# Regenerable caches only. NOTE: the LIGHT engine run outputs are intentionally
# NOT ignored — journals, candidates, frontier, best_solution, submissions are
# git-visible so optimization progress can be checked in and browsed.
.cache/
# the rendered dashboard site (regenerable via `solver report`)
out/
# per-candidate agent workdirs: trajectories + a per-candidate copy of kb/ (bulky, regenerable)
runs/*/work/

# Secrets — real keys live in .env (never committed); .env.example is the template.
.env
.env.*
!.env.example

# runtime backstop log (detached reap)
.reap-backstop.log
