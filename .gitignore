# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
build/
dist/

# Regenerable caches only. NOTE: engine run outputs are intentionally NOT
# ignored — journals, results, candidates, frontier, and best_solution are
# git-visible so optimization progress can be checked in and browsed.
.cache/

# Secrets — real keys live in .env (never committed); .env.example is the template.
.env
.env.*
!.env.example
