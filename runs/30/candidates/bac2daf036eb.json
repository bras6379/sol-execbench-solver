    "sources": [
      {
        "path": "kernel.py",
        "content": "import torch\n\ndef run(attn_output: torch.Tensor, residual: torch.Tensor, o_proj_weight: torch.Tensor) -> torch.Tensor:\n    \"\"\"\n    Fused attention output projection + residual.\n    Pre-fill output buffer with residual, then single GEMM with beta=1.0.\n    \"\"\"\n    # Compute M = batch * seq_len (the GEMM's M dimension)\n    M = attn_output.numel() // attn_output.shape[-1]  # B * S\n    N = residual.shape[-1]  # H = 2560\n\n    # Pre-fill output with residual\n    output = residual.clone()\n\n    # GEMM: output = output + attn_output @ o_proj_weight^T\n    # (output already holds residual, so this is fused add)\n    torch.addmm(output, attn_output, o_proj_weight.t(), beta=1.0, alpha=1.0)\n\n    return output\n"
      }
    ]
