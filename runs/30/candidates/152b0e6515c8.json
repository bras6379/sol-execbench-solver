    "sources": [
      {
        "path": "kernel.py",
        "content": "import torch\n\n\n@torch.no_grad()\ndef run(\n    attn_output: torch.Tensor,\n    residual: torch.Tensor,\n    o_proj_weight: torch.Tensor,\n) -> torch.Tensor:\n    \"\"\"\n    Fused attention output projection + residual add.\n\n    Computes output = attn_output @ o_proj_weight.T + residual by treating\n    the leading batch*seq dimensions as the GEMM M dimension and using a\n    single cuBLASLt call with the residual pre-loaded as the C matrix and\n    beta=1.0, fusing the matmul and add epilogue and eliminating the\n    intermediate projected tensor.\n    \"\"\"\n    B, S, H = attn_output.shape\n    M = B * S\n\n    attn_2d = attn_output.view(M, H)\n    residual_2d = residual.view(M, H)\n\n    out_2d = torch.addmm(\n        residual_2d,\n        attn_2d,\n        o_proj_weight.t(),\n        beta=1.0,\n        alpha=1.0,\n    )\n\n    return out_2d.view(B, S, H)\n"
      }
    ]
  },
