        "path": "kernel.py",
        "content": "import torch\n\n\n@torch.no_grad()\ndef run(\n    grad_output: torch.Tensor,\n    reshaped: torch.Tensor,\n    weight: torch.Tensor,\n) -> tuple[torch.Tensor, torch.Tensor]:\n    \"\"\"\n    Backward pass for attention output projection with reshape.\n\n    Both GEMMs run as bf16 tensor-core matmuls with fp32 accumulation, which is\n    numerically equivalent to the fp32 reference because all operands are\n    already bf16.  The input gradient is returned as a zero-copy transposed\n    (B, H, S, D) view so the reshape/transpose is never materialized.\n    \"\"\"\n    batch_size, seq_len, hidden_size = grad_output.shape\n\n    go2d = grad_output.reshape(-1, hidden_size)\n    rs2d = reshaped.reshape(-1, hidden_size)\n\n    # wgrad: (H*D, B*S) @ (B*S, H*D) -> (H*D, H*D)\n    grad_weight = go2d.t().mm(rs2d)\n\n    # dgrad: (B*S, H*D) @ (H*D, H*D) -> (B*S, H*D)\n    grad_reshaped_2d = go2d.mm(weight)\n\n    # Reverse the forward transpose+reshape as a zero-copy view.\n    grad_attn_output = grad_reshaped_2d.reshape(\n        batch_size, seq_len, 32, 64\n    ).transpose(1, 2)\n\n    return grad_attn_output, grad_weight\n"
