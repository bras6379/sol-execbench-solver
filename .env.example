# Copy to .env (gitignored) and fill in. `solver` auto-loads .env at startup and
# passes these through to agent CLIs (codex, claude, …) as environment variables.

# OpenAI (codex / gpt-5.5)
OPENAI_API_KEY=

# Cheap models over the claude CLI (Anthropic-compatible endpoints). Pick ONE path:
#  · OpenRouter — one key, every model. Use in --tier as openrouter/<model>, e.g.
#    openrouter/z-ai/glm-5.2, openrouter/deepseek/deepseek-v4, openrouter/moonshotai/kimi-k2.6
OPENROUTER_API_KEY=
#  · or direct per-provider (no markup) — --tier glm/glm-5.2, deepseek/deepseek-chat, kimi/kimi-k2.6
# ZAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=

# GPU (Phase F — docs/gpu-execution.md). Auto-provision: with just the API key +
# credit, `solver solve --gpu` creates an ephemeral pod, runs, and terminates it.
# RUNPOD_API_KEY=

# SOL-ExecBench leaderboard (research.nvidia.com) — `solver submit` / `solver
# leaderboard` use this JWT. Get it from the website; it expires periodically.
SOLBENCH_TOKEN=
# GPU_TYPE=NVIDIA B200
# GPU_IMAGE=                     # CUDA-13 base image (torch cu130) to boot the pod from
# NETWORK_VOLUME_ID=            # optional — persists the installed env for fast/cheap restarts
# GPU_SSH_KEY=~/.ssh/runpod     # key the created pod is provisioned with
# GPU_MAX_LIFETIME_MIN=120      # hard cap — pod self-terminates no matter what
# GPU_IDLE_TIMEOUT_MIN=15       # no jobs for this long -> terminate
# Manual BYO fallback (skip create/terminate): GPU_SSH_HOST / GPU_SSH_PORT / GPU_SSH_USER
