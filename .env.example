# Copy to .env (gitignored) and fill in. `solver` auto-loads .env at startup and
# passes these through to agent CLIs (codex, claude, …) as environment variables.

# OpenAI (codex / gpt-5.5)
OPENAI_API_KEY=

# Other providers (optional; add as you wire more agents)
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# GPU pod (Phase F — docs/gpu-execution.md). Rent a pod on RunPod, fill these in.
# GPU_SSH_HOST=
# GPU_SSH_PORT=22
# GPU_SSH_USER=root
# GPU_SSH_KEY=~/.ssh/runpod
# RUNPOD_API_KEY=
# RUNPOD_POD_ID=
